#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	cd D:\Reposity_github\CPlusPlus\Stdexec_Demo\build
	$(CMAKE_COMMAND) -P D:\Reposity_github\CPlusPlus\Stdexec_Demo\build\CMakeFiles\VerifyGlobs.cmake
	$(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles\Makefile.cmake 0
	cd D:\Reposity_github\CPlusPlus\Stdexec_Demo\build\stdexec\examples
.PHONY : cmake_check_build_system

